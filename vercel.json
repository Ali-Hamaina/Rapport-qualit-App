{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://localhost:3011/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "http://localhost:3011/uploads/:path*"
    }
  ]
}
